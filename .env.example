POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=5173

# Used by frontend container (build/run-time env for Vite dev server)
VITE_API_BASE_URL=http://backend:8000

# Django (optional, defaults are OK for dev)
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# fal.ai
# One key for the whole team; keep it out of git.
FAL_KEY=
FAL_ENDPOINT=fal-ai/nano-banana-2/edit
FAL_RESOLUTION=1K
FAL_ASPECT_RATIO=2:3
FAL_OUTPUT_FORMAT=jpeg
FAL_NUM_IMAGES=1
# 0 means "let model pick"; set explicit int for reproducibility.
FAL_SEED=0
# Downscale uploaded references to reduce upload size/latency (does not directly change pricing).
FAL_MAX_MEGAPIXELS=1
